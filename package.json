{
  "name": "agent-orchestra",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Agent 管理与调度面板 MVP",
  "main": "server.js",
  "bin": {
    "orchestra-plugin": "./bin/orchestra-plugin-cli.js"
  },
  "scripts": {
    "plugin:create": "node bin/orchestra-plugin-cli.js create",
    "plugin:validate": "node bin/orchestra-plugin-cli.js validate",
    "plugin:test": "node bin/orchestra-plugin-cli.js test",
    "plugin:publish": "node bin/orchestra-plugin-cli.js publish",
    "plugin:list-templates": "node bin/orchestra-plugin-cli.js list-templates",
    "start": "node server.js",
    "stop": "node stop.js",
    "status": "node status.js",
    "restart": "node restart.js",
    "verify": "node scripts/verify.js",
    "test": "node test/run-tests.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "build": "node scripts/build.js",
    "install-deps": "npm install @aws-sdk/client-s3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "better-sqlite3": "^9.0.0",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "mocha": "^10.0.0",
    "ws": "^8.20.0"
  }
}
